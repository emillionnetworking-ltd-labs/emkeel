# Emkeel — per-repo SCOPED credentials. Copy to .env (gitignored, chmod 600); NEVER commit real values.
# `emkeel connect` writes .env for you (hidden paste). Activate per-repo loading: `direnv allow` (or `source .envrc`).
# GH_TOKEN: a GitHub fine-grained PAT scoped to THIS repo (Contents RW, Pull requests RW, Metadata R).
GH_TOKEN=github_pat_scoped_to_THIS_repo
JIRA_BASE_URL=https://you.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_TOKEN=your-atlassian-api-token
