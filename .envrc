# emkeel — per-repo environment. Run `direnv allow` once to auto-load on `cd` into this repo
# (or `source .envrc` manually). Loads .env (gitignored, chmod 600): GH_TOKEN + JIRA_* scoped to
# THIS repo, so an agent in this window can't reach another repo's GitHub/Jira.
if [ -f .env ]; then set -a; . ./.env; set +a; fi
